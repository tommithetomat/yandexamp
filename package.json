{
  "name": "yandexamp",
  "version": "1.2.0",
  "description": "Десктопный плеер для Яндекс Музыки в стиле классического Winamp 2.x",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "keywords": [
    "winamp",
    "yandex-music",
    "electron",
    "player"
  ],
  "author": "tommi",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "ru.yandexamp.app",
    "productName": "YandexAmp",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "icon.ico"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "YandexAmp-${version}-Windows-Setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.music",
      "identity": null,
      "artifactName": "YandexAmp-${version}-macOS-${arch}.${ext}"
    }
  }
}
